# =============================================================================
# Instaply Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Database
DATABASE_PATH=data/instaply.db

# Server
HOST=127.0.0.1
PORT=8000

# --- LLM Provider ---
# Options: openai, anthropic, gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ALERT_TO_EMAIL=

# --- Scheduler ---
# Polling interval in seconds for high-priority sources
HIGH_PRIORITY_POLL_INTERVAL=300
# Polling interval in seconds for normal sources
NORMAL_POLL_INTERVAL=1800
# Source health check interval in seconds
HEALTH_CHECK_INTERVAL=1800

# --- Matching ---
# Default alert threshold (0-100)
DEFAULT_ALERT_THRESHOLD=85
# Digest threshold (scores between digest and alert get saved for review)
DIGEST_THRESHOLD=65

# --- Logging ---
LOG_LEVEL=INFO

# --- Digest delivery ---
# How often the digest job runs (seconds); 86400 = daily
DIGEST_INTERVAL=86400
# Only include matches first seen within this many days
DIGEST_LOOKBACK_DAYS=7
# Max jobs listed in one digest email (remainder summarized as a count)
DIGEST_MAX_ITEMS=20
